# ───────────────────────────── Node / npm ─────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# ─────────────────────────── Build output ─────────────────────────────
# tsup compiles src/ -> dist/, regenerated by `npm run build`.
dist/
*.tsbuildinfo
.tsup/

# ──────────────────── Model artifacts (generated) ─────────────────────
# Everything under model/ is produced by scripts/export_model.py and
# scripts/embed-assets.mjs: the .onnx files, labels.json, preprocess.json,
# and intermediate graphs (_probe / _try / .prep). Large binaries — never
# commit them.
#
# IMPORTANT: model/calib/ holds your calibration images. For an NSFW model
# those include explicit content. Keep them OUT of version control.
/model/

# Defensive: never commit a stray ONNX anywhere in the tree.
*.onnx
*.ort

# ──────────── Embedded model (auto-generated, can be large) ───────────
# scripts/embed-assets.mjs overwrites src/assets.generated.ts with the
# base64-embedded model (several MB). It is left TRACKED by default so a
# fresh clone can `npm run build` without the full Python/ONNX toolchain.
# If that blob bloats your git history, uncomment the line below and
# regenerate locally with `npm run embed-model` after each model change.
# src/assets.generated.ts

# ──────────────────── Python export environment ──────────────────────
# Throwaway venv used to run export_model.py (e.g. `uv venv .export-env`).
.export-env/
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ───────────────────── Scratch / verification ────────────────────────
# Temporary typecheck harness used during development.
.check/
*.tmp
tmp/
temp/

# ──────────────────────────── Secrets ────────────────────────────────
.env
.env.*
!.env.example

# ────────────────────────── Logs / coverage ──────────────────────────
*.log
coverage/
.nyc_output/

# ──────────────────────────── OS / editor ────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
