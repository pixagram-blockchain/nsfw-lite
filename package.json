{
  "name": "@pixagram/nsfw-lite",
  "version": "0.5.6",
  "description": "Fast on-device binary (sfw/nsfw) image classification for the browser — ~65 ms per image on CPU from a sub-1 MB-gzipped model. A uint8-quantized MobileNetV4-conv-small-050 runs through onnxruntime-web at 160px, tuned for pixel art, in a Web Worker with an automatic main-thread fallback. The model is base64-embedded as one self-contained bundle, so there's no runtime model fetch.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/mnv4/index.cjs",
  "module": "./dist/mnv4/index.js",
  "types": "./dist/mnv4/index.d.ts",
  "repository": {
    "url": "https://github.com/pixagram-blockchain/nsfw-lite.git",
    "type": "git"
  },
  "exports": {
    ".": {
      "types": "./dist/mnv4/index.d.ts",
      "import": "./dist/mnv4/index.js",
      "require": "./dist/mnv4/index.cjs"
    },
    "./mnv4": {
      "types": "./dist/mnv4/index.d.ts",
      "import": "./dist/mnv4/index.js",
      "require": "./dist/mnv4/index.cjs"
    },
    "./mnv4/worker": {
      "types": "./dist/mnv4/worker.d.ts",
      "import": "./dist/mnv4/worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": { "access": "public" },
  "scripts": {
    "embed-model": "node scripts/embed-assets.mjs",
    "embed:mnv4": "node scripts/embed-assets.mjs mnv4",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "onnxruntime-web": ">=1.19.0"
  },
  "devDependencies": {
    "onnxruntime-web": "^1.23.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "nsfw",
    "sfw",
    "content-moderation",
    "pixel-art",
    "onnx",
    "onnxruntime-web",
    "mobilenetv4",
    "image-classification",
    "web-worker",
    "browser",
    "client-side"
  ],
  "engines": {
    "node": ">=18"
  }
}
